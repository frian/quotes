{% extends 'base.html.twig' %}

{% block title %}{{ artist.name }}{% endblock %}

{% block body %}
    {% include '_detail_intro.html.twig' with {
        eyebrow: 'Artiste',
        title: artist.name,
        count: excerpts|length,
        summary: 'Dans le carnet, les extraits associés à cet artiste.',
        links: artist.albums|map(album => {
            label: album.title ~ ' · ' ~ album.releaseYear,
            url: path('album_show', { id: album.id })
        })
    } %}

    {% include 'excerpt/_list.html.twig' with { excerpts: excerpts, empty_message: 'Aucun extrait associé à cet artiste.' } %}
{% endblock %}
