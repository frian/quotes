{% extends 'base.html.twig' %}

{% block title %}{{ album.title }}{% endblock %}

{% block body %}
    {% include '_detail_intro.html.twig' with {
        eyebrow: 'Album',
        title: album.title,
        count: excerpts|length,
        summary: 'Le carnet rattache cet album à son artiste et à son année.',
        links: [
            { label: album.artist.name, url: path('artist_show', { id: album.artist.id }) },
            { label: album.releaseYear, url: path('year_show', { year: album.releaseYear }) }
        ]
    } %}

    {% include 'excerpt/_list.html.twig' with { excerpts: excerpts, empty_message: 'Aucun extrait associé à cet album.' } %}
{% endblock %}
