<section class="page-intro">
    <p>{{ eyebrow }}</p>

    <div>
        <h1>{{ title }}</h1>

        {% if count is defined and count is not null %}
            <p>
                {{ count }} extrait{{ count > 1 ? 's' : '' }}
            </p>
        {% endif %}
    </div>

    {% if summary is defined and summary %}
        <p>{{ summary }}</p>
    {% endif %}

    {% if links is defined and links is not empty %}
        <nav aria-label="{{ links_label|default('Liens associés') }}">
            {% for link in links %}
                <a href="{{ link.url }}" {% if link.external|default(false) %}rel="noopener noreferrer" target="_blank"{% endif %}>
                    {{ link.label }}
                </a>
            {% endfor %}
        </nav>
    {% endif %}
</section>
