{% extends 'base.html.twig' %}

{% block title %}{{ song.title }}{% endblock %}

{% block body %}
    <section class="page-intro">
        <p class="eyebrow">Chanson</p>
        <h1>{{ song.title }}</h1>
        <p class="page-subtitle">
            <a href="{{ path('album_show', { id: song.album.id }) }}">{{ song.album.title }}</a>
            ·
            <a href="{{ path('artist_show', { id: song.album.artist.id }) }}">{{ song.album.artist.name }}</a>
            ·
            <a href="{{ path('year_show', { year: song.album.releaseYear }) }}">{{ song.album.releaseYear }}</a>
        </p>
    </section>

    {% include 'excerpt/_list.html.twig' with { excerpts: excerpts, empty_message: 'Aucun extrait associé à cette chanson.' } %}
{% endblock %}
