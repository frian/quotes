{% extends 'base.html.twig' %}

{% block title %}{{ song.title }}{% endblock %}

{% block body %}
    {% include '_detail_intro.html.twig' with {
        eyebrow: 'Chanson',
        title: song.title,
        count: excerpts|length,
        summary: 'Une chanson, son album, son artiste et ses extraits accumulés au fil du temps.',
        links: [
            { label: song.album.title, url: path('album_show', { id: song.album.id }) },
            { label: song.album.artist.name, url: path('artist_show', { id: song.album.artist.id }) },
            { label: song.album.releaseYear, url: path('year_show', { year: song.album.releaseYear }) },
            { label: 'Écouter', url: song.sourceUrl, external: true, hidden: song.sourceUrl is empty }
        ]|filter(link => link.hidden is not defined or not link.hidden)
    } %}
    {% include 'excerpt/_list.html.twig' with { excerpts: excerpts, empty_message: 'Aucun extrait associé à cette chanson.' } %}
{% endblock %}
