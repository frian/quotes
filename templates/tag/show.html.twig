{% extends 'base.html.twig' %}

{% block title %}{{ tag.name }}{% endblock %}

{% block body %}
    {% include '_detail_intro.html.twig' with {
        eyebrow: 'Tag',
        title: tag.name,
        count: excerpts|length,
        summary: 'Tous les extraits marqués par ce tag.',
        links: is_granted('ROLE_ADMIN') ? [
            { label: 'Modifier', url: path('admin_tag_edit', { id: tag.id }) }
        ] : [],
    } %}
    {% include 'excerpt/_list.html.twig' with { excerpts: excerpts, empty_message: 'Aucun extrait associé à ce tag.' } %}
{% endblock %}
