{% extends 'base.html.twig' %}

{% block title %}Tags{% endblock %}

{% block body %}
    <section class="page-intro">
        <p class="eyebrow">Tags</p>
        <h1>Entrées par sensation, thème ou souvenir</h1>
        <p class="page-subtitle page-list">{{ tags|length }} tag{{ tags|length > 1 ? 's' : '' }} dans le carnet.</p>
    </section>

    {% if tags is empty %}
        <p class="empty-state">Aucun tag pour le moment.</p>
    {% else %}
        <nav class="index-list" aria-label="Liste des tags">
            {% for tag in tags %}
                <span class="index-list__item">
                    <a href="{{ path('tag_show', { id: tag.id }) }}">{{ tag.name }}</a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('admin_tag_edit', { id: tag.id }) }}">Modifier</a>
                    {% endif %}
                </span>
            {% endfor %}
        </nav>
    {% endif %}
{% endblock %}
