<article class="excerpt-card{% if variant is defined and variant %} excerpt-card--{{ variant }}{% endif %}">
    <blockquote class="excerpt-body">
        {{ excerpt.body|nl2br }}
    </blockquote>

    <footer class="excerpt-meta">
        <span>
            extrait de
            <a href="{{ path('song_show', { id: excerpt.song.id }) }}">
                {{ excerpt.song.title }}</a>
        </span><span>
            de l'album
            <a href="{{ path('album_show', { id: excerpt.song.album.id }) }}">
                {{ excerpt.song.album.title }}</a>
        </span>
        <span>
            de
            <a href="{{ path('artist_show', { id: excerpt.song.album.artist.id }) }}">
                {{ excerpt.song.album.artist.name }}</a>
        </span>
        <span>
            publié en
            <a href="{{ path('year_show', { year: excerpt.song.album.releaseYear }) }}">
                {{ excerpt.song.album.releaseYear }}</a>
        </span>
    </footer>

    {% if excerpt.tags is not empty %}
        <nav class="tag-list" aria-label="Tags de l’extrait">
            Tags : 
            {% for tag in excerpt.tags %}
                <div class="tag-wrapper">
                    <a href="{{ path('tag_show', { id: tag.id }) }}">{{ tag.name }}</a>
                </div>
            {% endfor %}
        </nav>
    {% endif %}

    <p class="admin-links">
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin_excerpt_edit', { id: excerpt.id }) }}">Modifier</a>
        {% endif %}
    </p>
</article>
