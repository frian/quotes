{% extends 'base.html.twig' %}

{% block title %}Années{% endblock %}

{% block body %}
    <section class="page-intro">
        <p>Années</p>
        <h1>Le carnet par millésimes</h1>
        <p>{{ years|length }} année{{ years|length > 1 ? 's' : '' }} repérée{{ years|length > 1 ? 's' : '' }}.</p>
    </section>

    {% if years is empty %}
        <p class="empty-state">Aucune année pour le moment.</p>
    {% else %}
        <nav class="index-list" aria-label="Liste des années">
            {% for year in years %}
                <a href="{{ path('year_show', { year: year }) }}">{{ year }}</a>
            {% endfor %}
        </nav>
    {% endif %}
{% endblock %}
