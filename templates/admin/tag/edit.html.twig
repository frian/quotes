{% extends 'base.html.twig' %}

{% block title %}Modifier {{ tag.name }}{% endblock %}

{% block body %}
    <section class="page-intro">
        <p>Correction</p>
        <h1>Modifier ce tag</h1>
        <p>Ajuster un nom, corriger une typo, ou retirer un tag devenu inutile.</p>
    </section>

    <section class="form-panel">
        {{ form_start(form) }}
            {{ form_errors(form) }}
            {{ form_row(form.name) }}
            <div class="color-select" data-controller="color-select">
                {{ form_label(form.color) }}
                {{ form_errors(form.color) }}
                {{ form_widget(form.color, { attr: { class: 'color-select__native', 'data-color-select-target': 'select', 'data-action': 'change->color-select#sync' } }) }}

                <button class="color-select__button" type="button" data-color-select-target="button" data-action="color-select#toggle">
                    <span class="color-select__swatch" data-color-select-target="swatch" aria-hidden="true"></span>
                    <span data-color-select-target="label">{{ form.color.vars.placeholder }}</span>
                </button>

                <div class="color-select__menu" data-color-select-target="menu" hidden>
                    {% for choice in form.color.vars.choices %}
                        <button
                            class="color-select__option"
                            type="button"
                            data-action="color-select#choose"
                            data-color-label="{{ choice.label }}"
                            data-color-value="{{ choice.value }}"
                            data-color-class="{{ choice.data.class }}"
                        >
                            <span class="color-select__swatch {{ choice.data.class }}" aria-hidden="true"></span>
                            <span>{{ choice.label }}</span>
                        </button>
                    {% endfor %}
                </div>
            </div>

            <div class="form-actions">
                {{ form_row(form.save) }}
            </div>
        {{ form_end(form) }}

        <form class="delete-form" method="post" action="{{ path('admin_tag_delete', { id: tag.id }) }}" onsubmit="return confirm('Supprimer définitivement ce tag ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_tag_' ~ tag.id) }}">
            <button type="submit">Supprimer le tag</button>
        </form>
    </section>
{% endblock %}
