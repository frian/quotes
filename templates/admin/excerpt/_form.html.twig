{{ form_start(form, { attr: { 'data-controller': 'excerpt-form' } }) }}
    {{ form_errors(form) }}

    <p class="form-intro" data-excerpt-form-target="reuseSummary">
        Ce formulaire réutilise automatiquement les artistes, albums, chansons et tags déjà enregistrés.
    </p>

    <div class="form-fieldset">
        <h2>Artiste</h2>
        <p class="form-hint" data-excerpt-form-target="artistHint">
            Utilisé seulement si tu crées un nouvel album.
        </p>
        {{ form_row(form.artist) }}
        {{ form_row(form.newArtistName) }}
    </div>

    <div class="form-fieldset">
        <h2>Album</h2>
        <p class="form-hint" data-excerpt-form-target="albumHint">
            Choisir un album existant remplit automatiquement l’artiste et l’année.
        </p>
        {{ form_row(form.album) }}
        {{ form_row(form.newAlbumTitle) }}
        {{ form_row(form.releaseYear) }}
    </div>

    {{ form_row(form.songTitle) }}
    {{ form_row(form.songSourceUrl) }}
    {{ form_row(form.body) }}
    {{ form_row(form.position) }}

    <div class="form-fieldset">
        <h2>Tags</h2>
        {{ form_row(form.tags) }}
        {{ form_row(form.newTagNames) }}
        <div class="color-select" data-controller="color-select">
            {{ form_label(form.newTagColor) }}
            {{ form_errors(form.newTagColor) }}
            {{ form_widget(form.newTagColor, { attr: { class: 'color-select__native', 'data-color-select-target': 'select', 'data-action': 'change->color-select#sync' } }) }}

            <button class="color-select__button" type="button" data-color-select-target="button" data-action="color-select#toggle">
                <span class="color-select__swatch" data-color-select-target="swatch" aria-hidden="true"></span>
                <span data-color-select-target="label">{{ form.newTagColor.vars.placeholder }}</span>
            </button>

            <div class="color-select__menu" data-color-select-target="menu" hidden>
                {% for choice in form.newTagColor.vars.choices %}
                    <button
                        class="color-select__option"
                        type="button"
                        data-action="color-select#choose"
                        data-color-label="{{ choice.label }}"
                        data-color-value="{{ choice.value }}"
                        data-color-class="{{ choice.data.class }}"
                    >
                        <span class="color-select__swatch {{ choice.data.class }}" aria-hidden="true"></span>
                        <span>{{ choice.label }}</span>
                    </button>
                {% endfor %}
            </div>
        </div>
    </div>

    {{ form_row(form.note) }}

    <div class="form-actions">
        {{ form_row(form.save) }}
    </div>
{{ form_end(form) }}
