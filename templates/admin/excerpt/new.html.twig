{% extends 'base.html.twig' %}

{% block title %}Ajouter un extrait{% endblock %}

{% block body %}
    <section class="page-intro">
        <p class="eyebrow">Saisie</p>
        <h1>Ajouter une page au carnet</h1>
    </section>

    <section class="form-panel">
        {{ form_start(form) }}
            {{ form_errors(form) }}

            {{ form_row(form.artistName) }}
            {{ form_row(form.albumTitle) }}
            {{ form_row(form.releaseYear) }}
            {{ form_row(form.songTitle) }}
            {{ form_row(form.body) }}
            {{ form_row(form.position) }}
            {{ form_row(form.tagNames) }}
            {{ form_row(form.note) }}

            <div class="form-actions">
                {{ form_row(form.save) }}
            </div>
        {{ form_end(form) }}
    </section>
{% endblock %}
