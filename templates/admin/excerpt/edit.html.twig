{% extends 'base.html.twig' %}

{% block title %}Modifier un extrait{% endblock %}

{% block body %}
    <section class="page-intro">
        <p class="eyebrow">Correction</p>
        <h1>Modifier cette page du carnet</h1>
    </section>

    <section class="form-panel">
        {% include 'admin/excerpt/_form.html.twig' with { form: form } %}

        <form class="delete-form" method="post" action="{{ path('admin_excerpt_delete', { id: excerpt.id }) }}" onsubmit="return confirm('Supprimer définitivement cet extrait ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_excerpt_' ~ excerpt.id) }}">
            <button type="submit">Supprimer l’extrait</button>
        </form>
    </section>
{% endblock %}
